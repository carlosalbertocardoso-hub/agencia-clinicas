# Database
DATABASE_URL=

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
# Debe ser un remitente verificado en Resend. Ejemplo: "iclinicas <info@iclinicas.es>"
RESEND_FROM_EMAIL="iclinicas <info@iclinicas.es>"
CONTACT_TO_EMAIL=info@iclinicas.es

# API Keys (si usas servicios externos)
GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=

# Analítica cliente (público — se inyecta en el HTML)
# ID de medición GA4 con formato G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Token de verificación de Google Search Console (método meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=

# Next.js
# Dominio público usado en enlaces, SEO y emails de confirmación
NEXT_PUBLIC_SITE_URL=https://www.iclinicas.es
