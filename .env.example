# Database
DATABASE_URL=

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
# Debe ser un remitente verificado en Resend. Ejemplo: "iclinicas <info@iclinicas.es>"
RESEND_FROM_EMAIL="iclinicas <info@iclinicas.es>"
CONTACT_TO_EMAIL=info@iclinicas.es

# API Keys (si usas servicios externos)
GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=

# Next.js
# Usa la URL temporal de Vercel durante desarrollo (ej: agencia-clinicas.vercel.app)
# Reemplaza con pacientessevilla.com una vez configures el dominio
NEXT_PUBLIC_SITE_URL=https://agencia-clinicas.vercel.app
